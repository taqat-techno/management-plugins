{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "py \"${CLAUDE_PLUGIN_ROOT}/hooks/pat_token_guard.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "py \"${CLAUDE_PLUGIN_ROOT}/hooks/source_file_protection.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "py \"${CLAUDE_PLUGIN_ROOT}/hooks/html_version_naming.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "py \"${CLAUDE_PLUGIN_ROOT}/hooks/git_pull_before_analysis.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "py \"${CLAUDE_PLUGIN_ROOT}/hooks/post_write_dispatcher.py\"",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "py \"${CLAUDE_PLUGIN_ROOT}/hooks/version_drift_detector.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "py \"${CLAUDE_PLUGIN_ROOT}/hooks/search_index_rebuild.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "py \"${CLAUDE_PLUGIN_ROOT}/hooks/session_end_lessons.py\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
